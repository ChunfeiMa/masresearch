# === Secrets (set as GitHub repo secrets for the Actions pipeline) ===
# Anthropic — powers the summarize / classify / diagram agents
ANTHROPIC_API_KEY=sk-ant-...

# Tavily — hourly web search for blogs / solutions / product launches
TAVILY_API_KEY=tvly-...

# === LangSmith tracing (optional but recommended) ===
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=masresearcher

# === Model selection ===
# Deep work (summaries, diagrams); cheap work (dedup hints, tagging)
MAS_MODEL_DEEP=claude-opus-4-8
MAS_MODEL_FAST=claude-haiku-4-5-20251001

# === Run tuning ===
# Max new items to fully enrich per run (cost guard)
MAS_MAX_ITEMS_PER_RUN=40
# Lookback window (hours) for "new" items from each source
MAS_LOOKBACK_HOURS=24
